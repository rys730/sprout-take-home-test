                    {
                        "type": "string",
                        "description": "Search by code or name",
                        "name": "search",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by account type (asset, liability, equity, revenue, expense)",
                        "name": "type",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by parent account ID",
                        "name": "parent_id",
                        "in": "query"
                    }
